// 네이버 부동산 분석 프로젝트 Prisma Schema (Prisma 7)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. 사용자 관리 (개인 데이터)
// ============================================

model User {
  id            String    @id @default(cuid()) /// 사용자 고유 ID (CUID)
  email         String?   @unique              /// 사용자 이메일 (소셜 로그인 포함)
  name          String?                        /// 사용자 이름
  password      String?                        /// 해시된 비밀번호 (local 로그인용)
  role          String    @default("user")     /// 사용자 역할 (user, admin)
  provider      String    @default("local")    /// 로그인 제공자 (local, google, kakao)
  providerId    String?                        /// OAuth 제공자 ID
  lastLoginAt   DateTime?                      /// 마지막 로그인 일시
  createdAt     DateTime  @default(now())      /// 계정 생성일
  updatedAt     DateTime  @updatedAt           /// 정보 수정일

  // 중개사 정보
  phone         String?                        /// 휴대폰 번호
  zipCode       String?                        /// 우편번호
  address       String?                        /// 주소 (중개업소)
  detailAddress String?                        /// 상세 주소
  companyName   String?                        /// 상호 (중개업소명)
  businessNumber String?                       /// 사업자등록번호

  // 테마 설정
  themeMode     String    @default("smart")    /// 테마 모드 (light, dark, system, smart)
  accentColor   String    @default("cyan")     /// 강조 색상 (cyan, indigo, pink, orange, green, red)
  fontSize      String    @default("medium")   /// 폰트 크기 (small, medium, large)
  borderRadius  String    @default("medium")   /// 테두리 둥글기 (sharp, medium, rounded)
  compactMode   Boolean   @default(false)      /// 컴팩트 모드 여부

  // 관계 - 사용자 개인 데이터
  properties       Property[]                  /// 사용자 매물 목록
  savedProperties  SavedProperty[]             /// 저장한 매물 목록
  searchConditions SearchCondition[]           /// 저장한 검색 조건
  priceAlerts      PriceAlert[]                /// 가격 알림
  notes            Note[]                      /// 매물 메모
  watchAreas       WatchArea[]                 /// 관심 지역/단지
  managedProperties ManagedProperty[]          /// 관리 매물 목록
  favoriteProperties FavoriteProperty[]         /// 관심 매물 목록
  schedules        Schedule[]                  /// 일정 목록
  customerInfos    CustomerInfo[]              /// 고객 정보 목록

  @@map("users")
}

// ============================================
// 2. 저장한 매물 (찜)
// ============================================

model SavedProperty {
  id          String   @id @default(cuid())    /// 저장 매물 고유 ID
  userId      String                          /// 사용자 ID
  articleNo   String                          /// 네이버 매물 번호
  complexNo   String?                         /// 단지 번호 (아파트/오피스텔)
  complexName String?                         /// 단지명

  // 캐시된 매물 정보 (원본 조회 없이 표시용)
  cachedName  String?                         /// 매물명 캐시
  cachedPrice Int?                            /// 가격 캐시 (만원)
  cachedType  String?                         /// 매물타입 캐시
  cachedTrade String?                         /// 거래방식 캐시

  // 매물 전체 정보 (정규 매물 그리드 표시용)
  articleData String?  @db.Text               /// 매물 전체 정보 JSON

  isFavorite  Boolean  @default(false)        /// 즐겨찾기 여부
  notes       String?                         /// 간단 메모

  createdAt   DateTime @default(now())        /// 저장일
  updatedAt   DateTime @updatedAt             /// 수정일

  // 관계
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleNo])
  @@index([userId])
  @@index([articleNo])
  @@map("saved_properties")
}

// ============================================
// 3. 검색 조건 저장
// ============================================

model SearchCondition {
  id          String   @id @default(cuid())    /// 검색 조건 고유 ID
  userId      String                          /// 사용자 ID
  name        String                          /// 사용자 정의 이름

  // 검색 조건
  cortarNo    String?                         /// 지역 코드
  regionName  String?                         /// 지역명 캐시
  realEstateTypes String?                     /// 매물 유형 (콜론 구분: APT:OPST:VL)
  tradeTypes  String?                         /// 거래 유형 (콜론 구분: A1:B1:B2)
  priceMin    Int?                            /// 최소 가격 (만원)
  priceMax    Int?                            /// 최대 가격 (만원)
  areaMin     Float?                          /// 최소 면적 (㎡)
  areaMax     Float?                          /// 최대 면적 (㎡)

  // 정렬 기본값
  defaultOrder String?                        /// 기본 정렬 (rank, price, area)

  isDefault   Boolean  @default(false)        /// 기본 검색 여부

  createdAt   DateTime @default(now())        /// 생성일
  updatedAt   DateTime @updatedAt             /// 수정일

  // 관계
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isDefault])
  @@map("search_conditions")
}

// ============================================
// 4. 가격 알림
// ============================================

model PriceAlert {
  id          String   @id @default(cuid())    /// 알림 고유 ID
  userId      String                          /// 사용자 ID
  name        String                          /// 알림 이름

  // 대상
  articleNo   String?                         /// 특정 매물 번호
  complexNo   String?                         /// 특정 단지 번호
  cortarNo    String?                         /// 특정 지역 코드

  // 조건
  alertType   String                          /// 알림 유형 (below: 가격 하락, above: 상승, change: 변동률)
  targetPrice Int?                            /// 목표 가격 (만원)
  changeRate  Float?                          /// 변동률 (%)

  // 상태
  isActive    Boolean  @default(true)         /// 활성화 여부
  isTriggered Boolean  @default(false)        /// 발동 여부
  triggeredAt DateTime?                       /// 발동 일시

  createdAt   DateTime @default(now())        /// 생성일
  updatedAt   DateTime @updatedAt             /// 수정일

  // 관계
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("price_alerts")
}

// ============================================
// 5. 매물 메모
// ============================================

model Note {
  id          String   @id @default(cuid())    /// 메모 고유 ID
  userId      String                          /// 사용자 ID
  articleNo   String                          /// 매물 번호

  content     String   @db.Text               /// 메모 내용
  tags        String?                         /// 태그 JSON 배열 (예: ["관리비저렴", "역세권"])

  createdAt   DateTime @default(now())        /// 생성일
  updatedAt   DateTime @updatedAt             /// 수정일

  // 관계
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([articleNo])
  @@map("notes")
}

// ============================================
// 6. 토큰 관리 (공용)
// ============================================

model NaverToken {
  id          Int      @id @default(autoincrement()) /// 토큰 ID
  accessToken String   @unique                    /// 네이버 API 액세스 토큰
  expiresAt   DateTime                           /// 만료 일시
  cookies     String?                            /// 쿠키 문자열 (크롤링용)
  createdAt   DateTime @default(now())           /// 생성일
  updatedAt   DateTime @updatedAt                /// 수정일

  @@map("naver_tokens")
}

// ============================================
// 7. 지역 관리 (공용)
// ============================================

model Region {
  id            Int      @id @default(autoincrement()) /// 지역 ID
  cortarNo      String   @unique                       /// 법정동 코드
  cortarName    String                                 /// 법정동 이름
  cortarType    String                                 /// 지역 타입 (city: 시도, dvsn: 시군구, dongs: 읍면동)
  parentCortarNo String?                                /// 상위 지역 코드
  centerLat     Float?                                 /// 중심 위도
  centerLon     Float?                                 /// 중심 경도
  depth         Int      @default(0)                   /// 계층 깊이 (0: 시도, 1: 시군구, 2: 읍면동)
  createdAt     DateTime @default(now())               /// 생성일
  updatedAt     DateTime @updatedAt                    /// 수정일

  // 관계
  parent        Region?  @relation("RegionHierarchy", fields: [parentCortarNo], references: [cortarNo])
  children      Region[] @relation("RegionHierarchy")
  complexes     Complex[]                              /// 소속 단지 목록

  @@index([parentCortarNo])
  @@index([cortarType])
  @@map("regions")
}

// ============================================
// 8. 단지 캐시 (일시적, TTL 기준 삭제 가능)
// ============================================

model Complex {
  id                    Int      @id @default(autoincrement()) /// 단지 ID
  complexNo             String   @unique                       /// 네이버 단지 번호
  complexName           String                                 /// 단지명
  realEstateTypeCode    String                                 /// 매물 유형 코드 (APT, OPST)
  realEstateTypeName    String                                 /// 매물 유형명 (아파트, 오피스텔)
  latitude              Float                                  /// 위도
  longitude             Float                                  /// 경도
  cortarNo              String                                 /// 지역 코드
  cortarAddress         String?                                /// 단지 주소 (지구 주소, 예: "서울시 용산구 한강로2가")
  roadAddress           String?                                /// 도로명 주소 (예: "한강대로43길 8")
  detailAddress         String?                                /// 상세 주소 (예: "2-8")

  // 단지 정보
  completionYearMonth   String?                                /// 준공년월 (YYYYMM)
  totalDongCount        Int?                                   /// 동 수
  totalHouseholdCount   Int?                                   /// 세대수
  floorAreaRatio        Int?                                   /// 용적률 (%)
  minArea               Float?                                 /// 최소 면적 (㎡)
  maxArea               Float?                                 /// 최대 면적 (㎡)
  representativeArea    Float?                                 /// 대표 면적 (㎡)

  // 매물 카운트 (캐시된 값)
  dealCount             Int      @default(0)                   /// 매매 매물 수
  leaseCount            Int      @default(0)                   /// 전세 매물 수
  rentCount             Int      @default(0)                   /// 월세 매물 수
  totalArticleCount     Int      @default(0)                   /// 전체 매물 수

  // 캐시 관리
  lastCrawledAt          DateTime?                              /// 마지막 크롤링 일시
  cacheExpiresAt         DateTime?                              /// 캐시 만료 일시

  createdAt             DateTime @default(now())               /// 생성일
  updatedAt             DateTime @updatedAt                    /// 수정일

  // 관계
  region                Region   @relation(fields: [cortarNo], references: [cortarNo])
  watchAreas            WatchArea[]                            /// 관심 지역 설정

  @@index([cortarNo])
  @@index([realEstateTypeCode])
  @@index([latitude, longitude])
  @@index([cacheExpiresAt])
  @@map("complexes")
}

// ============================================
// 9. 매물 캐시 (일시적, TTL 기준 삭제 가능)
// ============================================

model Property {
  id                    Int      @id @default(autoincrement()) /// 매물 ID
  articleNo             String   @unique                       /// 네이버 매물 번호

  // 기본 정보
  articleName           String                                 /// 매물명
  articleStatus         String                                 /// 매물 상태 (R0: 정상, etc.)
  realEstateTypeCode    String                                 /// 매물 유형 코드 (APT, OPST, VL, ONEROOM, TWOROOM, SG, etc.)
  realEstateTypeName    String                                 /// 매물 유형명 (아파트, 오피스텔, 빌라, 원룸, etc.)

  // 거래 정보
  tradeTypeCode         String                                 /// 거래 유형 코드 (A1: 매매, B1: 전세, B2: 월세, B3: 단기임대)
  tradeTypeName         String                                 /// 거래 유형명 (매매, 전세, 월세, 단기임대)

  // 가격 정보 (만원 단위)
  dealOrWarrantPrc      Int?                                   /// 매매가 또는 보증금 (만원)
  rentPrc               Int?                                   /// 월세 (만원)

  // 면적 정보 (㎡)
  area1                 Float?                                 /// 공급면적 (㎡)
  area2                 Float?                                 /// 전용면적 (㎡)

  // 상세 정보
  floorInfo             String?                                /// 층수 정보 (예: 3/5, B1/3, 지하1층/3층)
  direction             String?                                /// 방향 (남향, 남동향, etc.)
  buildingName          String?                                /// 건물명

  // 위치 정보
  latitude              Float?                                 /// 위도
  longitude             Float?                                 /// 경도
  cortarNo              String                                 /// 지역 코드
  cortarAddress         String?                                /// 단지 주소 (지구 주소, 예: "서울시 용산구 한강로2가")
  roadAddress           String?                                /// 도로명 주소 (예: "한강대로43길 8")
  detailAddress         String?                                /// 상세 주소 (동/호수)

  // 기타 정보
  articleConfirmYmd     String?                                /// 매물 확정일 (YYYYMMDD)
  articleFeatureDesc    String?                                /// 매물 설명

  // 중개사 정보
  cpName                String?                                /// 중개업소명
  realtorName           String?                                /// 중개사명
  managerName           String?                                /// 책임자 이름
  managerPhone          String?                                /// 책임자 전화번호
  cpPcArticleUrl        String?                                /// PC 매물 상세 URL
  cpMobileArticleUrl    String?                                /// 모바일 매물 상세 URL

  // 거래 정보
  tradeCheckedByOwner   Boolean  @default(false)             /// 주인 확인 여부 (거래 완료 여부)
  isDirectTrade         Boolean  @default(false)             /// 직거래 여부

  // 추가 정보
  tagList               String?                                /// 태그 리스트 JSON 배열 (예: ["역세권", "새아파트"])

  // 단지 정보 (아파트/오피스텔만 해당)
  complexNo             String?                                /// 소속 단지 번호

  // 사용자 소유
  userId                String?                                /// 소유 사용자 ID (null이면 공용)

  // 데이터 소스 구분
  dataSource            String   @default("NAVER")             /// 데이터 소스 (NAVER: 네이버 크롤링, UPLOAD: 파일 업로드)

  // 캐시 관리
  lastCrawledAt          DateTime?                              /// 마지막 크롤링 일시
  cacheExpiresAt         DateTime?                              /// 캐시 만료 일시

  createdAt             DateTime @default(now())               /// DB 저장 일시
  updatedAt             DateTime @updatedAt                    /// 정보 수정 일시

  priceHistories        PriceHistory[]                         /// 가격 이력
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cortarNo])
  @@index([realEstateTypeCode])
  @@index([tradeTypeCode])
  @@index([articleConfirmYmd])
  @@index([latitude, longitude])
  @@index([cacheExpiresAt])
  @@index([dataSource])
  @@index([userId])
  @@map("properties")
}

// ============================================
// 10. 가격 히스토리 (시계열 데이터)
// ============================================

model PriceHistory {
  id            Int      @id @default(autoincrement()) /// 가격 이력 ID
  propertyId    Int                                  /// 매물 ID
  tradeTypeCode String                               /// 거래 유형 코드 (A1, B1, B2, B3)
  price         Int                                  /// 기록된 가격 (만원)

  recordedAt    DateTime @default(now())             /// 기록 일시

  // 관계
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([recordedAt])
  @@map("price_histories")
}

// ============================================
// 11. 크롤링 로그
// ============================================

model ScrapLog {
  id           Int       @id @default(autoincrement()) /// 크롤링 로그 ID
  targetUrl    String                               /// 크롤링 대상 URL
  targetType   String                               /// 대상 타입 (complexes: 단지, articles: 매물, regions: 지역)
  status       String                               /// 상태 (success: 성공, failed: 실패, pending: 대기중)
  itemCount    Int       @default(0)                /// 수집된 항목 수

  errorMessage String?                              /// 에러 메시지
  startedAt    DateTime  @default(now())           /// 시작 일시
  completedAt  DateTime?                            /// 완료 일시

  @@index([status])
  @@index([startedAt])
  @@map("scrap_logs")
}

// ============================================
// 12. 관심 지역/단지 설정
// ============================================

model WatchArea {
  id             String   @id @default(cuid())    /// 관심 지역 고유 ID
  userId         String                          /// 사용자 ID
  name           String                          /// 사용자 정의 이름

  cortarNo       String?                         /// 지역 코드 (지역 기반 설정)
  complexNo      String?                         /// 단지 번호 (단지 기반 설정)

  // 크롤링 설정
  crawlInterval  Int      @default(60)           /// 크롤링 주기 (분)
  isActive       Boolean  @default(true)         /// 활성화 여부

  createdAt      DateTime @default(now())        /// 생성일
  updatedAt      DateTime @updatedAt             /// 수정일

  // 관계
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  complex        Complex? @relation(fields: [complexNo], references: [complexNo])

  @@index([userId])
  @@index([cortarNo])
  @@index([complexNo])
  @@map("watch_areas")
}

// ============================================
// 13. 고객 정보
// ============================================

model CustomerInfo {
  id                  String    @id @default(cuid())    /// 고객 정보 고유 ID
  userId              String                            /// 사용자 ID
  customerKey         String                            /// 고객 매칭 키 (내부용)
  customerName        String                            /// 고객명
  customerPhone       String?                           /// 연락처
  memo                String?   @db.Text               /// 고객 메모
  createdAt           DateTime  @default(now())         /// 등록일
  updatedAt           DateTime  @updatedAt              /// 수정일

  // 관계
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, customerKey])
  @@index([userId])
  @@map("customer_info")
}

// ============================================
// 14. 관리 매물 (계약 관리)
// ============================================

model ManagedProperty {
  id                  String    @id @default(cuid())    /// 관리 매물 고유 ID
  userId              String                            /// 사용자 ID

  // 매물 기본 정보
  articleName         String                            /// 매물명
  buildingName        String?                           /// 건물명/단지명
  address             String?                           /// 주소
  propertyId          Int?                              /// properties 테이블 참조 (선택)

  // 거래 유형
  contractType        String                            /// 매매, 전세, 월세
  propertyType        String?                           /// 매물 유형 (아파트, 오피스텔, 빌라 등)

  // ── 계약금 ──
  downPayment         Int?                              /// 계약금 (만원)
  downPaymentDate     DateTime?                         /// 계약금 납부일

  // ── 중도금 ──
  interimPayment      Int?                              /// 중도금 (만원)
  interimPaymentDate  DateTime?                         /// 중도금 납부일

  // ── 잔금 ──
  finalPayment        Int?                              /// 잔금 (만원)
  finalPaymentDate    DateTime?                         /// 잔금 납부일

  // 계약 기간
  contractDate        DateTime                          /// 계약 시작일
  contractEndDate     DateTime                          /// 계약 만료일

  // 금액 정보
  totalPrice          Int?                              /// 총 거래금액 (만원)
  depositAmount       Int?                              /// 보증금 (만원, 전세/월세)
  monthlyRent         Int?                              /// 월세 (만원)

  // 관리 정보
  tenantName          String?                           /// 세입자명
  tenantPhone         String?                           /// 세입자 연락처
  managerName         String?                           /// 책임자명
  managerPhone        String?                           /// 책임자 전화번호
  lastNotificationSentAt DateTime?                      /// 최근 책임자 알림 발송일시
  notificationHistory Json?                             /// 알림 종류별 발송 이력
  notes               String?                           /// 메모

  // 상태
  status              String    @default("active")      /// active, expired, renewed

  createdAt           DateTime  @default(now())         /// 생성일
  updatedAt           DateTime  @updatedAt              /// 수정일

  // 관계
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contractEndDate])
  @@index([finalPaymentDate])
  @@index([interimPaymentDate])
  @@index([status])
  @@map("managed_properties")
}

// ============================================
// 15. 관심 매물 (독립 - 네이버 데이터 무관)
// ============================================

model FavoriteProperty {
  id                  String    @id @default(cuid())    /// 관심 매물 고유 ID
  userId              String                            /// 사용자 ID

  // 매물 기본 정보
  articleName         String                            /// 매물명
  buildingName        String?                           /// 건물명/단지명
  address             String?                           /// 주소
  propertyType        String?                           /// 매물 유형 (아파트, 오피스텔, 빌라 등)
  tradeType           String?                           /// 거래 유형 (매매, 전세, 월세)
  price               Int?                              /// 가격 (만원)
  area                Float?                            /// 면적 (㎡)
  notes               String?                           /// 메모

  createdAt           DateTime  @default(now())         /// 저장일
  updatedAt           DateTime  @updatedAt              /// 수정일

  // 관계
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("favorite_properties")
}

// ============================================
// 15. 일정 관리
// ============================================

model Schedule {
  id               String    @id @default(cuid())    /// 일정 고유 ID
  userId           String                            /// 사용자 ID

  // 일정 정보
  title            String                            /// 일정 제목
  description      String?                           /// 일정 설명
  startTime        DateTime                          /// 시작 일시
  endTime          DateTime?                         /// 종료 일시
  type             String    @default("default")     /// 일정 유형 (meeting, task, event, break, default)
  location         String?                           /// 장소

  // 알림
  isAllDay         Boolean   @default(false)         /// 하루 종부 여부
  reminderMinutes  Int?                              /// 알림 시간 (분 단위, null: 알림 없음)

  // 반복 일정
  isRecurring      Boolean   @default(false)         /// 반복 일정 여부
  recurrenceRule   String?                           /// 반복 규칙 (JSON: daily, weekly, monthly, yearly + interval + days)
  recurrenceEnd    DateTime?                         /// 반복 종료일
  parentEventId    String?                           /// 부모 일정 ID (반복 생성된 일정의 원본)

  // 색상 및 우선순위
  color            String?                           /// 일정 색상 (hex)
  priority         String    @default("medium")      /// 우선순위 (low, medium, high, urgent)

  // 참여자
  attendees        String?                           /// 참여자 (JSON 배열)

  // 상태
  status           String    @default("confirmed")   /// 상태 (confirmed, tentative, cancelled, completed)

  createdAt        DateTime  @default(now())         /// 생성일
  updatedAt        DateTime  @updatedAt              /// 수정일

  // 관계
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startTime])
  @@index([parentEventId])
  @@map("schedules")
}
