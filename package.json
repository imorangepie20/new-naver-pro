    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.5",
    "hono": "^4.12.2",
    "lucide-react": "^0.344.0",
    "node-fetch": "^3.3.2",
